@{
    string controller = HttpContext.Current.Request.RequestContext.RouteData.Values["controller"].ToString().ToLower();
    string action = HttpContext.Current.Request.RequestContext.RouteData.Values["action"].ToString().ToLower();
    bool connected = Session["ConnectedUser"] != null;
    var connectedUser = connected ? (PhotosManager.Models.User)Session["ConnectedUser"] : null;
    bool admin = connected ? connectedUser.Admin : false;
    bool superAdmin = connected ? connectedUser.Id == 1 : false;
    bool asc = Session["Ascendant"] != null ? (bool)Session["Ascendant"] : false;
    string sortType = Session["PhotosSortType"] != null ? (string)Session["PhotosSortType"] : "date";
    string sortDirecton = "[tri descendant]";
    if (Session["Ascendant"] != null)
    {
        sortDirecton = (bool)Session["Ascendant"] ? " [tri ascendant]" : "[tri descendant]";
    }
}
<div id="header">
    <a href="/Photos/List?sortType=dates">
        <img src="/Content/UI-Images/PhotoCloudLogo.png" class="appLogo" alt="" title="Gestionnaire de photos">
    </a>
    @switch (action)
    {
        case "list":
            <div class="actionTitle">Photos </div>
            <div class="menu-icon-layout">
                @switch (sortType)
                {
                    case "dates":<a href="/Photos/List?sortType=likes" class="cmdIcon fa fa-calendar" title="Tri par date"></a>
                        break;
                    case "likes":<a href="/Photos/List?sortType=comments" class="cmdIcon fa fa-thumbs-up" title="Tri par popularité"></a>
                        break;
                    case "comments":<a href="/Photos/List?sortType=dates" class="cmdIcon fa fa-comment" title="Tri par nombre de commentaires"></a>
                        break;
                    default:
                        break;
                }
                @if (!asc)
                {
                    <a href="/@controller/ToggleSortDirection" class="cmdIcon fa fa-arrow-circle-up" title="Tri descendant"></a>
                }
                else
                {
                    <a href="/@controller/ToggleSortDirection" class="cmdIcon fa fa-arrow-circle-down" title="Tri ascendant"></a>
                }
                @if (connected)
                {
                    <a href="/@controller/Create" class="cmdIcon fa fa-plus" title="Ajouter une photo"></a>
                }


                <a href="/@controller/ToggleSearch" class="cmdIcon fa fa-search" title="Afficher/Masquer la barre de recherche"></a>
                <div class="dropdown">
                    <div data-bs-toggle="dropdown" aria-expanded="false">
                        <i id="notificationsIcon" class="cmdIcon fa fa-regular fa-bell"></i>
                    </div>
                    <div id="notificationsPanel" class="dropdown-menu noselect"> </div>
                </div>
                <a href="/Accounts/EditProfil" class="noDecoration">
                    @Helper.Image(connectedUser.Avatar, "UserHeaderAvatar")
                </a>
                <div class="dropdown">
                    <div data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="cmdIcon fa fa-ellipsis-vertical"></i>
                    </div>

                    <div class="dropdown-menu noselect">
                        @if (connected)
                        {
                            <div class="dropdown-item">
                                <a href="/Accounts/EditProfil" class="noDecoration">
                                    @Helper.Image(connectedUser.Avatar, "xsmallAvatar ") Profil...
                                </a>
                            </div>
                            if (admin)
                            {
                                <div class="dropdown-item">
                                    <a href="/Accounts/ManageUsers" class="noDecoration">
                                        <i class="menuIcon fa fa-users"></i> Gestion des usagers...
                                    </a>
                                </div>
                                <div class="dropdown-item">
                                    <a href="/Accounts/LoginsJournal" class="noDecoration">
                                        <i class="menuIcon fa fa-calendar"></i> Historique de connexions...
                                    </a>
                                </div>
                                if (superAdmin)
                                {
                                    <div class="dropdown-item">
                                        <a href="/Accounts/EventsJournal" class="noDecoration">
                                            <i class="menuIcon fa fa-calendar"></i> Historique de événements...
                                        </a>
                                    </div>
                                }
                            }
                            <div class="dropdown-item">
                                <a href="/Accounts/Logout" class="noDecoration">
                                    <i class="menuIcon fa fa-sign-out"></i> Déconnexion...
                                </a>
                            </div>
                        }
                        <div class="dropdown-divider"></div>

                        <a href="/@controller/ToggleSortDirection" class="dropdown-item">
                            <i class="menuIcon fa fa-image mx-2"></i> Liste des photos @sortDirecton
                        </a>
                        @if (ViewBag.Title == "Liste des photos")
                        {
                            sortType = Session["PhotosSortType"] != null ? (string)Session["PhotosSortType"] : "date";

                            string checkIcon = "<i class='menuIcon fa fa-check mx-2'></i>";
                            string uncheckIcon = "<i class='menuIcon fa fa-fw mx-2'></i>";
                            string sortByDatesCheck = (sortType == "dates") ? checkIcon : uncheckIcon;
                            string sortByLikesCheck = (sortType == "likes") ? checkIcon : uncheckIcon;
                            string sortByCommentsCheck = (sortType == "comments") ? checkIcon : uncheckIcon;
                            string filterByDontLikeCheck = (sortType == "ownerDontLike") ? checkIcon : uncheckIcon;
                            string filterByLikeCheck = (sortType == "ownerLikes") ? checkIcon : uncheckIcon;
                            string filterByNoCommentCheck = (sortType == "ownerNoComment") ? checkIcon : uncheckIcon;
                            string filterByCommentedCheck = (sortType == "ownerComments") ? checkIcon : uncheckIcon;

                            <a href="/Photos/List?sortType=dates" class="dropdown-item">
                                @Html.Raw(sortByDatesCheck) <i class="menuIcon fa fa-calendar mx-2"></i>par date de création
                            </a>
                            <a href="/Photos/List?sortType=likes" class="dropdown-item">
                                @Html.Raw(sortByLikesCheck) <i class="menuIcon fa fa-heart mx-2"></i>par popularité
                            </a>
                            <a href="/Photos/List?sortType=comments" class="dropdown-item">
                                @Html.Raw(sortByCommentsCheck) <i class="menuIcon fa fa-comment mx-2"></i>par nombre de commentaires
                            </a>
                            <div class="dropdown-divider"></div>
                            <a href="/Photos/List?sortType=ownerDontLike" class="dropdown-item">
                                @Html.Raw(filterByDontLikeCheck) <i class="menuIcon fa-regular fa-thumbs-up mx-2"></i>que je n'aime pas
                            </a>
                            <a href="/Photos/List?sortType=ownerLikes" class="dropdown-item">
                                @Html.Raw(filterByLikeCheck) <i class="menuIcon fa fa-thumbs-up mx-2"></i>que j'aime
                            </a>
                            <a href="/Photos/List?sortType=ownerNoComment" class="dropdown-item">
                                @Html.Raw(filterByNoCommentCheck) <i class="menuIcon fa-regular fa-comment mx-2"></i>que je n'ai pas commenté
                            </a>
                            <a href="/Photos/List?sortType=ownerComments" class="dropdown-item">
                                @Html.Raw(filterByCommentedCheck) <i class="menuIcon fa fa-comment mx-2"></i>que j'ai commenté
                            </a>
                        }
                        <div class="dropdown-divider"></div>
                        <div class="dropdown-item">
                            <a href="/Home/About" class="noDecoration">
                                <i class="menuIcon fa fa-info-circle"></i> À propos...
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            break;
        case "details":
            <div class="actionTitle">Détails </div>
            <div class="menu-icon-layout">
                @if (connected && (Session["IsOwner"] != null ? (bool)Session["IsOwner"] : false))
                {
                    <a href="/@controller/Edit" class="cmdIcon fa fa-edit" title="Modifier"></a>
                    <i class="cmdIcon fa fa-trash"
                       title="Effacer"
                       onclick="bootbox.confirm('Effacer?', function(result){ if (result) window.location = '/@controller/Delete'; })">
                    </i>

                }
                <a href="/Photos/List" class="cmdIcon fa fa-times" title="Annuler"></a>
            </div>
            break;
        case "create":
            <div class="actionTitle">Ajout </div>
            <div class="menu-icon-layout">
                <i class="cmdIcon submitCmd fa fa-check" title="Soumettre"></i>
                <a href="/Photos/List" class="cmdIcon fa fa-times" title="Annuler"></a>
            </div>
            break;
        case "edit":
            <div class="actionTitle">Modification </div>
            <div class="menu-icon-layout">
                <i class="cmdIcon submitCmd fa fa-check" title="Soumettre"></i>
                <a href="/@controller/details/@Session["currentPhotoId"]" class="cmdIcon fa fa-times" title="Annuler"></a>
            </div>
            break;
        case "about":
            <div class="actionTitle">À propos </div>
            <div class="menu-icon-layout">
                <i onclick="history.back()" class="cmdIcon fa fa-times" title="Fermer"></i>
            </div>
            break;
        case "login":
            <div class="actionTitle">@ViewBag.Title</div>
            break;
        case "subscribe":
            <div class="actionTitle">@ViewBag.Title </div>
            <div class="menu-icon-layout">
                <i class="cmdIcon submitCmd fa fa-check" title="Soumettre"></i>
                <a href="/Accounts/login" class="cmdIcon fa fa-times" title="Annuler"></a>
            </div>
            break;
        case "editprofil":
            <div class="actionTitle">@ViewBag.Title </div>
            <div class="menu-icon-layout">
                <i class="cmdIcon submitCmd fa fa-check" title="Soumettre"></i>
                <i onclick="history.back()" class="cmdIcon fa fa-times" title="Fermer"></i>
            </div>
            break;
        case "manageusers":
            <div class="actionTitle">@ViewBag.Title </div>
            <div class="menu-icon-layout">
                <i onclick="history.back()" class="cmdIcon fa fa-times" title="Fermer"></i>
            </div>
            break;
        case "renewpasswordcommand":
            <div class="actionTitle">
                @ViewBag.Title
            </div>
            <div class="menu-icon-layout">
                <a href="/Accounts/RenewPasswordCancelled" class="cmdIcon fa fa-times" title="Annuler"></a>
            </div>
            break;
        case "renewpassword":
            <div class="actionTitle">@ViewBag.Title </div>
            <div class="menu-icon-layout">
                <a href="/Accounts/RenewPasswordCancelled" class="cmdIcon fa fa-times" title="Annuler"></a>
            </div>
            break;
        case "loginsjournal":
            <div class="actionTitle">@ViewBag.Title </div>
            <div class="menu-icon-layout">
                <i onclick="history.back()" class="cmdIcon fa fa-times" title="Fermer"></i>
            </div>
            break;
        case "eventsjournal":
            <div class="actionTitle">@ViewBag.Title </div>
            <div class="menu-icon-layout">
                <i onclick="history.back()" class="cmdIcon fa fa-times" title="Fermer"></i>
            </div>
            break;

    }
</div>

